      {
        "id": "7ef6e316-7e2e-4df7-92ba-80f8c148409e",
        "type": "heading",
        "width": "normal",
        "align": "left",
        "surface": "none",
        "spaceTop": 26,
        "spaceBottom": 12,
        "title": "Процесс работы",
        "level": 2,
        "anchor": "процесс-работы",
        "imageHeight": 720,
        "imageWidth": 80,
        "spacerHeight": 48,
        "tableCaption": "",
