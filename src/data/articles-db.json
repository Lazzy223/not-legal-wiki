      {
        "id": "94afa64c-c408-49a0-bd48-5861ac82b9fb",
        "type": "text",
        "width": "normal",
        "align": "left",
        "surface": "none",
        "spaceTop": 12,
        "spaceBottom": 12,
        "html": "<ul><li><p>Уровень персонажа — не ниже <strong>3-го</strong>.</p></li></ul><p></p>",
        "level": 2,
        "imageHeight": 720,
        "spacerHeight": 48,
        "tableCaption": "",
