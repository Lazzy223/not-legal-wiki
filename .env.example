# Секрет подписи сессий. Используй длинную случайную строку.
AUTH_SECRET=replace-with-a-long-random-secret

# Основной вариант: Upstash Redis.
# При установке интеграции через Vercel эти переменные обычно добавляются автоматически.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Также поддерживаются старые имена переменных интеграции Vercel KV:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Необязательно. Не меняй после первого запуска, иначе будет создано новое пустое пространство данных.
DATA_STORE_PREFIX=not-legal-rp:v1
